# Covenant Indexer Configuration

# Oracle wallet private key (base64 or hex, from `sui keytool export`)
ORACLE_PRIVATE_KEY=

# Covenant package ID (deployed on testnet)
COVENANT_PACKAGE_ID=0xc48189767a999e843bcfc6ad8fcfca8a259935f7807d0c971b199af10a682044

# OracleCap object ID
ORACLE_CAP_ID=0x080a0bcbb2c511cbaf711b00ae9b65e1769238349648faae7df8e24928961e7d

# EVE World contract package ID (for KillmailCreatedEvent type)
# Get this from the EVE Frontier documentation or Sui explorer
WORLD_PACKAGE_ID=

# Sui RPC and GraphQL endpoints
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_GRAPHQL_URL=https://graphql.testnet.sui.io/graphql

# Polling interval in seconds (default: 30)
POLL_INTERVAL=30
