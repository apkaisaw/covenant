# Covenant Indexer Configuration

# Oracle wallet private key (base64 or hex, from `sui keytool export`)
ORACLE_PRIVATE_KEY=

# Covenant package ID (deployed on testnet)
COVENANT_PACKAGE_ID=0xc48837bf062d2d9ac489a6d9ce89fbfd8c77920e58f498efb7581800a615b3da

# OracleCap object ID
ORACLE_CAP_ID=0x6113acd7281d0386d0b5cd3f6fe832354a11f39972a8066e963fd0d217b0a595

# EVE World contract package ID (for KillmailCreatedEvent type)
# Get this from the EVE Frontier documentation or Sui explorer
